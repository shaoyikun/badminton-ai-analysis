# Runtime ports
BACKEND_PORT=8787
FRONTEND_PORT=5173

# Frontend API base URL
# Leave blank to use same-origin requests in Docker Compose.
# Local dev scripts will still default to http://127.0.0.1:${BACKEND_PORT}.
VITE_API_BASE=

# Python entry used by backend scripts and local development
PYTHON_BIN=python3

# Optional pose model overrides for analysis-service
# Leave blank to use analysis-service/models/pose_landmarker_lite.lock.json
# and the default analysis-service/models cache directory.
POSE_LANDMARKER_MODEL_PATH=
POSE_LANDMARKER_MODEL_CACHE_DIR=

# Backend upload limit in bytes
UPLOAD_MAX_FILE_SIZE_BYTES=209715200

# Docker build mirror for backend image dependencies
APT_MIRROR=mirrors.aliyun.com
